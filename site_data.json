    "childrens-books": {
      "title": "Children's Books",
      "type": "sections",
      "sections": [
        {
          "title": "Building a Home",
          "description": "<b><i>Building a Home</i></b> tells the tale of six children from Kazakhstan, Pakistan, Mexico, and Syria who moved to Nogojiwanong-Peterborough, Canada. The narrative integrates the experiences of these young individuals as they acquire English proficiency and acclimate to their new surroundings. Casandra collaborated individually with each child to document their accounts, and the children produced striking visuals during this collaboration. The publication was commissioned by the <a href=\"https://www.nccpeterborough.ca/\" target=\"_blank\" rel=\"noopener noreferrer\">New Canadians Centre</a> and appears in seven language versions.",
          "images": [
            {
              "src": "assets/childrens-books/building-a-home-01.jpg",
              "alt": "Building a Home - Cover"
            },
            {
              "src": "assets/childrens-books/building-a-home-02.jpg",
